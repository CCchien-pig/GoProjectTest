            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"points\": [\n    {\n      \"recorded_at\": \"2026-07-09T13:00:00Z\",\n      \"metric_name\": \"temperature\",\n      \"value\": 36.5,\n      \"unit\": \"C\"\n    },\n    {\n      \"recorded_at\": \"2026-07-09T13:00:00Z\",\n      \"metric_name\": \"humidity\",\n      \"value\": 55.0,\n      \"unit\": \"%\"\n    }\n  ]\n}"

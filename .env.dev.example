# .env.dev.example
# ────────────────────────────────────────────────────────────────
# 使用方式：
#   cp .env.dev.example .env.dev
#   然後修改 .env.dev 中的帳密為你自己的設定
#
# 注意：.env.dev 已被 .gitignore 排除，不會進入版本控制。
#       此 .example 檔案才會進 Git，作為格式範本。
# ────────────────────────────────────────────────────────────────

# App
APP_ENV=development
API_PORT=8080

# ─────────────────────────────────────────────────────────────────
# PostgreSQL（本地 Docker）
# ─────────────────────────────────────────────────────────────────
POSTGRES_USER=udm
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=udm
DATABASE_URL=postgres://udm:your_password_here@localhost:5432/udm?sslmode=disable&client_encoding=UTF8
DB_MAX_CONNS=10
DB_MIN_CONNS=2

# ─────────────────────────────────────────────────────────────────
# ScyllaDB（本地 Docker）
# ─────────────────────────────────────────────────────────────────
SCYLLA_HOSTS=localhost:9042
SCYLLA_KEYSPACE=udm

# ─────────────────────────────────────────────────────────────────
# KeyDB（本地 Docker — 本地開發不啟用密碼）
# ─────────────────────────────────────────────────────────────────
KEYDB_ADDR=localhost:6379
KEYDB_PASSWORD=
KEYDB_CLUSTER_MODE=false
KEYDB_USE_TLS=true
KEYDB_CA_CERT_PATH=.docker/certs/ca.crt
KEYDB_INSECURE_SKIP_VERIFY=true
